FROM registry.cn-hangzhou.aliyuncs.com/devflow/golang:1.25.8 AS builder

WORKDIR /workspace
ENV GOPROXY=https://goproxy.cn,direct

COPY devflow-service-common /workspace/devflow-service-common
COPY devflow-config-service /workspace/devflow-config-service
COPY devflow-config-repo /workspace/devflow-config-repo

WORKDIR /workspace/devflow-config-service
RUN go mod download
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/devflow-config-service ./cmd

FROM alpine:3.22
WORKDIR /app
RUN apk add --no-cache git openssh-client ca-certificates && \
    adduser -D devuser
COPY --from=builder /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/
COPY --from=builder --chown=devuser:devuser /out/devflow-config-service ./devflow-config-service
COPY --from=builder --chown=devuser:devuser /workspace/devflow-config-service/docs ./docs
COPY --from=builder --chown=devuser:devuser /workspace/devflow-config-repo ./config-repo
EXPOSE 8082
USER devuser
ENTRYPOINT ["/app/devflow-config-service"]
